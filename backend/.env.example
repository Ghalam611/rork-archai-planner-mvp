# ===========================================
# ArchAI Planner Backend - Environment Variables
# ===========================================

# OpenAI API Configuration
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase Database Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:8081,exp://192.168.1.100:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
JWT_SECRET=your-jwt-secret-key-for-authentication
API_KEY_HEADER=x-api-key

# ===========================================
# Setup Instructions:
# ===========================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Replace placeholder values with your actual keys
#
# 3. Install dependencies:
#    npm install
#
# 4. Start development server:
#    npm run dev
#
# 5. Deploy to production:
#    npm run deploy
#
# ===========================================
# Security Notes:
# ===========================================
# - NEVER commit .env file to version control
# - Use different keys for development and production
# - Rotate API keys regularly
# - Monitor API usage and costs
# - Use strong JWT secrets
#
# ===========================================
# Deployment Platforms:
# ===========================================
# This backend can be deployed to:
# - Vercel (recommended for Node.js)
# - Netlify Functions
# - Railway
# - Heroku
# - AWS Lambda
# - DigitalOcean App Platform
#
# See DEPLOYMENT.md for detailed deployment guides
